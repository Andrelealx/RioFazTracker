{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "strictPropertyInitialization": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "types": ["node"],
    "baseUrl": "./",
    "paths": {
      "@riofaz/shared": ["../../packages/shared/src"],
      "@riofaz/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["src/**/*"]
}
