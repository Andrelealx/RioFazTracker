{
  "name": "riofaztracker",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "npm run prisma:migrate && npm --workspace @riofaz/api run start",
    "dev": "npm run dev:api",
    "dev:api": "npm --workspace @riofaz/api run start:dev",
    "dev:web": "echo \"Frontend servido pela API em apps/api/public\"",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "postinstall": "npm run prisma:generate",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate": "prisma migrate deploy --schema prisma/schema.prisma",
    "prisma:seed": "tsx prisma/seed.ts",
    "legacy:migrate": "tsx scripts/migrate-legacy-sql.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "bcryptjs": "^3.0.2"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "prisma": "^6.7.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
